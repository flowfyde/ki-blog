---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const related = allPosts.filter(p => p.slug !== post.slug).slice(0, 4);
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{post.data.title} — Flowfy Blog</title>
  <meta name="description" content={post.data.description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Sans:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f8f7f4; --bg2: #f0ede8;
      --border: #e8e4dd; --border2: #d4cfc7;
      --text: #1a1815; --text2: #6b6660; --text3: #9b9590;
      --accent: #1a6b4a; --accent-light: #e8f4ee; --accent2: #2d8f65;
      --news: #dc2626; --news-light: #fef2f2;
      --radius: 12px; --radius-lg: 20px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
      --shadow: 0 4px 16px rgba(0,0,0,0.08);
    }
    html { background: var(--bg); color: var(--text); font-family: 'Instrument Sans', sans-serif; -webkit-font-smoothing: antialiased; }
    body { overflow-x: hidden; }

    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 max(2rem, calc((100vw - 1200px) / 2));
      background: rgba(248,247,244,0.88); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-family: 'Cabinet Grotesk', sans-serif; font-weight: 900; font-size: 1.25rem; color: var(--text); text-decoration: none; letter-spacing: -0.03em; }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 0.25rem; align-items: center; }
    .nav-links a { font-size: 0.875rem; color: var(--text2); text-decoration: none; padding: 0.4rem 0.75rem; border-radius: 8px; transition: all 0.15s; font-weight: 500; }
    .nav-links a:hover, .nav-links a.active { color: var(--text); background: var(--bg2); }
    .nav-cta { background: var(--accent) !important; color: white !important; }
    .nav-cta:hover { background: var(--accent2) !important; }

    .progress-bar { position: fixed; top: 64px; left: 0; right: 0; height: 3px; background: var(--border); z-index: 99; }
    .progress-fill { height: 100%; background: var(--news); width: 0%; transition: width 0.1s linear; }

    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

    .breadcrumb {
      padding: 88px 0 0; display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.78rem; color: var(--text3);
    }
    .breadcrumb a { color: var(--text3); text-decoration: none; transition: color 0.15s; }
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb-sep { color: var(--border2); }

    .layout {
      display: grid; grid-template-columns: 1fr 300px;
      gap: 3.5rem; align-items: start; padding: 2rem 0 5rem;
    }

    /* ARTICLE */
    .article-header { margin-bottom: 2rem; }

    .news-badge {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-size: 0.7rem; font-weight: 700; color: var(--news);
      background: var(--news-light); border: 1px solid rgba(220,38,38,0.15);
      padding: 0.25rem 0.7rem; border-radius: 4px; margin-bottom: 1rem;
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .news-dot { width: 6px; height: 6px; background: var(--news); border-radius: 50%; animation: pulse 1.5s ease infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

    h1 {
      font-family: 'Cabinet Grotesk', sans-serif;
      font-size: clamp(1.8rem, 3.5vw, 2.5rem); font-weight: 900;
      letter-spacing: -0.03em; line-height: 1.1; color: var(--text); margin-bottom: 1rem;
    }

    .article-meta {
      display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
      font-size: 0.78rem; color: var(--text3);
      padding: 0.85rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      margin-bottom: 1.75rem;
    }
    .meta-date { font-weight: 600; color: var(--text2); }
    .meta-sep { color: var(--border2); }
    .updated-badge {
      font-size: 0.68rem; font-weight: 600; color: var(--accent);
      background: var(--accent-light); padding: 0.15rem 0.5rem;
      border-radius: 4px;
    }

    .hero-img { width: 100%; border-radius: var(--radius-lg); margin-bottom: 2rem; display: block; box-shadow: var(--shadow); }

    .prose { line-height: 1.8; }
    .prose h2 {
      font-family: 'Cabinet Grotesk', sans-serif; font-size: 1.35rem; font-weight: 800;
      letter-spacing: -0.02em; color: var(--text); margin: 2.5rem 0 0.85rem;
      display: flex; align-items: center; gap: 0.6rem;
    }
    .prose h2::before { content: ''; width: 4px; height: 1.2em; background: var(--news); border-radius: 2px; flex-shrink: 0; }
    .prose h3 { font-family: 'Cabinet Grotesk', sans-serif; font-size: 1.05rem; font-weight: 700; color: var(--text); margin: 1.75rem 0 0.6rem; }
    .prose p { font-size: 0.95rem; color: var(--text2); margin-bottom: 1.1rem; line-height: 1.8; }
    .prose strong { color: var(--text); font-weight: 600; }
    .prose a { color: var(--accent); text-decoration: underline; text-decoration-color: rgba(26,107,74,0.3); }
    .prose a:hover { text-decoration-color: var(--accent); }
    .prose ul, .prose ol { padding-left: 1.5rem; margin-bottom: 1.25rem; }
    .prose li { font-size: 0.95rem; color: var(--text2); margin-bottom: 0.4rem; line-height: 1.7; }
    .prose li::marker { color: var(--news); }
    .prose blockquote {
      border-left: 3px solid var(--news); margin: 1.5rem 0;
      padding: 0.85rem 1.25rem; background: var(--news-light);
      border-radius: 0 var(--radius) var(--radius) 0;
    }
    .prose blockquote p { color: var(--news); font-style: italic; margin: 0; font-weight: 500; }
    .prose hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
    .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.875rem; }
    .prose th { background: var(--bg2); padding: 0.6rem 0.85rem; text-align: left; font-weight: 600; border-bottom: 2px solid var(--border2); }
    .prose td { padding: 0.6rem 0.85rem; border-bottom: 1px solid var(--border); color: var(--text2); }

    /* HIGHLIGHTS BOX */
    .highlight-box {
      background: white; border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 1.25rem 1.5rem;
      margin: 1.75rem 0;
    }
    .highlight-box-title { font-family: 'Cabinet Grotesk', sans-serif; font-size: 0.85rem; font-weight: 700; color: var(--text); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.4rem; }

    .article-footer {
      margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;
    }
    .footer-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
    .footer-tag { font-size: 0.72rem; padding: 0.2rem 0.6rem; border-radius: 100px; border: 1px solid var(--border2); color: var(--text3); }
    .footer-share { display: flex; gap: 0.5rem; }
    .share-btn {
      font-size: 0.75rem; padding: 0.3rem 0.75rem; border-radius: 8px;
      border: 1px solid var(--border2); background: white; color: var(--text2);
      cursor: pointer; font-family: 'Instrument Sans', sans-serif; text-decoration: none;
      transition: all 0.15s; display: inline-flex; align-items: center; gap: 0.3rem;
    }
    .share-btn:hover { background: var(--bg2); color: var(--text); }

    /* SIDEBAR */
    .sidebar { position: sticky; top: 88px; display: flex; flex-direction: column; gap: 1rem; }

    .sidebar-card { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem; }
    .sidebar-title { font-family: 'Cabinet Grotesk', sans-serif; font-size: 0.85rem; font-weight: 700; color: var(--text); margin-bottom: 0.85rem; }

    .news-item {
      display: flex; gap: 0.75rem; padding: 0.65rem 0;
      border-bottom: 1px solid var(--border); text-decoration: none;
      transition: all 0.15s;
    }
    .news-item:last-child { border-bottom: none; padding-bottom: 0; }
    .news-item:hover .news-item-title { color: var(--accent); }
    .news-item-num { font-family: 'Cabinet Grotesk', sans-serif; font-size: 1.1rem; font-weight: 900; color: var(--border2); flex-shrink: 0; line-height: 1; padding-top: 2px; }
    .news-item-title { font-size: 0.8rem; font-weight: 500; color: var(--text); line-height: 1.35; transition: color 0.15s; margin-bottom: 0.2rem; }
    .news-item-date { font-size: 0.7rem; color: var(--text3); }

    .ticker {
      background: var(--text); border-radius: var(--radius-lg); padding: 1.25rem; overflow: hidden;
    }
    .ticker-label { font-size: 0.65rem; font-weight: 700; color: var(--news); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.6rem; display: flex; align-items: center; gap: 0.4rem; }
    .ticker-dot { width: 5px; height: 5px; background: var(--news); border-radius: 50%; animation: pulse 1.5s ease infinite; }
    .ticker-items { display: flex; flex-direction: column; gap: 0.5rem; }
    .ticker-item { font-size: 0.78rem; color: rgba(255,255,255,0.65); line-height: 1.4; padding-left: 0.75rem; border-left: 2px solid rgba(255,255,255,0.1); }

    .nl-card { background: var(--accent); border-radius: var(--radius-lg); padding: 1.25rem; }
    .nl-title { font-family: 'Cabinet Grotesk', sans-serif; font-size: 0.9rem; font-weight: 800; color: white; margin-bottom: 0.4rem; }
    .nl-card p { font-size: 0.75rem; color: rgba(255,255,255,0.7); line-height: 1.5; margin-bottom: 0.85rem; }
    .nl-input { width: 100%; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.2); color: white; padding: 0.55rem 0.75rem; border-radius: 8px; font-size: 0.78rem; font-family: 'Instrument Sans', sans-serif; outline: none; margin-bottom: 0.5rem; }
    .nl-input::placeholder { color: rgba(255,255,255,0.4); }
    .nl-btn { width: 100%; background: white; color: var(--accent); border: none; padding: 0.55rem; border-radius: 8px; font-size: 0.78rem; font-weight: 600; cursor: pointer; font-family: 'Instrument Sans', sans-serif; }
    .nl-btn:hover { opacity: 0.9; }

    footer { border-top: 1px solid var(--border); padding: 2rem 0; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-top: 4rem; }
    .footer-logo { font-family: 'Cabinet Grotesk', sans-serif; font-weight: 900; font-size: 1rem; color: var(--text2); text-decoration: none; }
    .footer-logo span { color: var(--accent); }
    .footer-links { display: flex; gap: 1.5rem; }
    .footer-links a { font-size: 0.78rem; color: var(--text3); text-decoration: none; transition: color 0.15s; }
    .footer-links a:hover { color: var(--text); }

    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { display: none; }
      .nav-links { display: none; }
    }
  </style>
</head>
<body>

<nav>
  <a href="/" class="nav-logo">Flowfy<span>.</span></a>
  <div class="nav-links">
    <a href="/ratgeber">KI-Ratgeber</a>
    <a href="/blog" class="active">Blog</a>
    <a href="/ueber-mich">Über mich</a>
    <a href="/kontakt">Kontakt</a>
    <a href="https://claude.ai" target="_blank" class="nav-cta">Claude testen →</a>
  </div>
</nav>

<div class="progress-bar"><div class="progress-fill" id="progress"></div></div>

<div class="wrap">
  <div class="breadcrumb">
    <a href="/">Flowfy</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/blog">Blog</a>
    <span class="breadcrumb-sep">›</span>
    <span style="color:var(--text2)">{post.data.title}</span>
  </div>

  <div class="layout">

    <article>
      <div class="article-header">
        <div class="news-badge"><span class="news-dot"></span> KI News</div>
        <h1>{post.data.title}</h1>
        <div class="article-meta">
          <span class="meta-date">📅 {post.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          <span class="meta-sep">·</span>
          <span>⏱ ca. 3 Min. Lesezeit</span>
          <span class="meta-sep">·</span>
          <span>✍️ Flowfy-Autor</span>
          <span class="updated-badge">Aktuell</span>
        </div>
      </div>

      {post.data.heroImage && (
        <img
          src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage.src}
          alt={post.data.title}
          class="hero-img"
        />
      )}

      <div class="prose">
        <Content />
      </div>

      <div class="article-footer">
        <div class="footer-tags">
          <span class="footer-tag">KI News</span>
          <span class="footer-tag">Aktuell</span>
          <span class="footer-tag">2025</span>
        </div>
        <div class="footer-share">
          <button class="share-btn" onclick="navigator.clipboard.writeText(window.location.href).then(()=>this.textContent='✅ Kopiert!')">🔗 Link kopieren</button>
          <a class="share-btn" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent('https://flowfy.de/blog/' + post.slug)}`} target="_blank">𝕏 Teilen</a>
        </div>
      </div>
    </article>

    <div class="sidebar">

      <div class="ticker">
        <div class="ticker-label"><span class="ticker-dot"></span> KI Ticker</div>
        <div class="ticker-items">
          <div class="ticker-item">Claude 4 mit erweiterten Agenten-Fähigkeiten verfügbar</div>
          <div class="ticker-item">OpenAI GPT-5 offiziell angekündigt</div>
          <div class="ticker-item">Google Gemini 2.0 übertrifft GPT-4 in Benchmarks</div>
          <div class="ticker-item">EU AI Act tritt in Kraft — das ändert sich</div>
        </div>
      </div>

      {related.length > 0 && (
        <div class="sidebar-card">
          <div class="sidebar-title">Weitere News</div>
          {related.map((p, i) => (
            <a href={`/blog/${p.slug}/`} class="news-item">
              <span class="news-item-num">0{i + 1}</span>
              <div>
                <div class="news-item-title">{p.data.title}</div>
                <div class="news-item-date">{p.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long' })}</div>
              </div>
            </a>
          ))}
        </div>
      )}

      <div class="nl-card">
        <div class="nl-title">KI News per Mail</div>
        <p>Bleib auf dem Laufenden — jeden Dienstag das Wichtigste aus der KI-Welt.</p>
        <form onsubmit="return false;">
          <input type="email" class="nl-input" placeholder="deine@email.de" />
          <button type="submit" class="nl-btn">Abonnieren →</button>
        </form>
      </div>

    </div>
  </div>
</div>

<div class="wrap">
  <footer>
    <a href="/" class="footer-logo">Flowfy<span>.</span></a>
    <div class="footer-links">
      <a href="/ratgeber">Ratgeber</a>
      <a href="/blog">Blog</a>
      <a href="/ueber-mich">Über mich</a>
      <a href="/kontakt">Kontakt</a>
    </div>
    <span style="font-size:0.75rem;color:var(--text3)">© {new Date().getFullYear()} Flowfy</span>
  </footer>
</div>

<script>
  const progress = document.getElementById('progress');
  window.addEventListener('scroll', () => {
    const total = document.documentElement.scrollHeight - window.innerHeight;
    progress.style.width = Math.round((window.scrollY / total) * 100) + '%';
  });
</script>

</body>
</html>
