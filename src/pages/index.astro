---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="de">
  <head>
    <BaseHead title="flowfy.de — KI einfach erklärt" description="KI-Tools, Claude-Guides und praktische Prompts für Anfänger. Kein Fachwissen nötig." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #0a0a0f;
        --bg2: #111118;
        --bg3: #1a1a24;
        --border: rgba(255,255,255,0.07);
        --border-hover: rgba(255,255,255,0.15);
        --accent: #7c6bff;
        --accent2: #a78bfa;
        --accent-glow: rgba(124,107,255,0.15);
        --text: #f0eff8;
        --text-muted: #8b8a9e;
        --text-dim: #5a5970;
        --tag-bg: rgba(124,107,255,0.12);
        --tag-text: #a78bfa;
      }

      html { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; scroll-behavior: smooth; }

      body { min-height: 100vh; overflow-x: hidden; }

      /* NOISE OVERLAY */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 0;
        opacity: 0.4;
      }

      /* GLOW ORBS */
      .orb {
        position: fixed;
        border-radius: 50%;
        filter: blur(120px);
        pointer-events: none;
        z-index: 0;
      }
      .orb-1 { width: 600px; height: 600px; background: rgba(124,107,255,0.08); top: -200px; right: -100px; }
      .orb-2 { width: 400px; height: 400px; background: rgba(167,139,250,0.05); bottom: 10%; left: -100px; }

      /* NAV */
      nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        padding: 0 2rem;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(10,10,15,0.8);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
      }

      .nav-logo {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 1.1rem;
        color: var(--text);
        text-decoration: none;
        letter-spacing: -0.02em;
      }

      .nav-logo span { color: var(--accent2); }

      .nav-links { display: flex; gap: 2rem; align-items: center; }
      .nav-links a {
        font-size: 0.875rem;
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.2s;
        font-weight: 400;
      }
      .nav-links a:hover { color: var(--text); }

      .nav-cta {
        background: var(--accent);
        color: white !important;
        padding: 0.4rem 1rem;
        border-radius: 6px;
        font-size: 0.8rem !important;
        font-weight: 500 !important;
        transition: opacity 0.2s !important;
      }
      .nav-cta:hover { opacity: 0.85; color: white !important; }

      /* WRAPPER */
      .wrapper { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; padding: 0 2rem; }

      /* HERO */
      .hero {
        padding: 160px 0 100px;
        position: relative;
      }

      .hero-label {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--accent2);
        background: var(--tag-bg);
        border: 1px solid rgba(124,107,255,0.2);
        padding: 0.3rem 0.75rem;
        border-radius: 100px;
        margin-bottom: 1.5rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .hero-label::before {
        content: '';
        width: 6px; height: 6px;
        background: var(--accent);
        border-radius: 50%;
        animation: pulse 2s ease infinite;
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
      }

      h1 {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2.8rem, 6vw, 5rem);
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: -0.03em;
        color: var(--text);
        margin-bottom: 1.5rem;
        max-width: 14ch;
      }

      h1 .gradient {
        background: linear-gradient(135deg, #7c6bff 0%, #a78bfa 50%, #c4b5fd 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .hero-sub {
        font-size: 1.125rem;
        color: var(--text-muted);
        line-height: 1.7;
        max-width: 50ch;
        margin-bottom: 2.5rem;
        font-weight: 300;
      }

      .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--accent);
        color: white;
        text-decoration: none;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s;
        box-shadow: 0 0 30px rgba(124,107,255,0.3);
      }
      .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 0 40px rgba(124,107,255,0.4); }

      .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-muted);
        text-decoration: none;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 400;
        border: 1px solid var(--border);
        transition: all 0.2s;
      }
      .btn-secondary:hover { color: var(--text); border-color: var(--border-hover); background: var(--bg3); }

      /* STATS BAR */
      .stats {
        display: flex;
        gap: 3rem;
        padding: 2rem 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        margin-bottom: 5rem;
        flex-wrap: wrap;
      }

      .stat-item {}
      .stat-num {
        font-family: 'Syne', sans-serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.03em;
      }
      .stat-num span { color: var(--accent2); }
      .stat-label { font-size: 0.8rem; color: var(--text-dim); margin-top: 2px; }

      /* SECTION TITLE */
      .section-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .section-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.02em;
      }

      .section-link {
        font-size: 0.85rem;
        color: var(--accent2);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        transition: gap 0.2s;
      }
      .section-link:hover { gap: 0.5rem; }

      /* FEATURED POST */
      .featured {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
      }

      @media (max-width: 700px) {
        .featured { grid-template-columns: 1fr; }
        h1 { font-size: 2.4rem; }
        .stats { gap: 1.5rem; }
        nav { padding: 0 1rem; }
        .nav-links { display: none; }
      }

      .post-card {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        transition: all 0.25s;
        position: relative;
      }

      .post-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(124,107,255,0.05) 0%, transparent 60%);
        opacity: 0;
        transition: opacity 0.25s;
      }

      .post-card:hover {
        border-color: var(--border-hover);
        transform: translateY(-2px);
        box-shadow: 0 8px 40px rgba(0,0,0,0.3);
      }
      .post-card:hover::before { opacity: 1; }

      .post-card.featured-main {
        grid-row: span 2;
      }

      .post-img {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        display: block;
        filter: saturate(0.8) brightness(0.85);
        transition: filter 0.3s;
      }
      .post-card:hover .post-img { filter: saturate(1) brightness(0.95); }

      .post-card.featured-main .post-img { aspect-ratio: 4/3; }

      .post-body {
        padding: 1.25rem 1.5rem 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      .post-tag {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 500;
        color: var(--tag-text);
        background: var(--tag-bg);
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        margin-bottom: 0.75rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .post-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1.3;
        margin-bottom: 0.6rem;
        letter-spacing: -0.01em;
      }

      .post-card.featured-main .post-title { font-size: 1.4rem; }

      .post-desc {
        font-size: 0.875rem;
        color: var(--text-muted);
        line-height: 1.6;
        flex: 1;
        font-weight: 300;
      }

      .post-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
      }

      .post-date {
        font-size: 0.75rem;
        color: var(--text-dim);
      }

      .post-arrow {
        margin-left: auto;
        color: var(--accent2);
        font-size: 1rem;
        transition: transform 0.2s;
      }
      .post-card:hover .post-arrow { transform: translateX(3px); }

      /* SMALL POSTS GRID */
      .posts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
        margin-bottom: 5rem;
      }

      .post-card-small {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1.25rem;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: all 0.2s;
        position: relative;
        overflow: hidden;
      }

      .post-card-small::after {
        content: '→';
        position: absolute;
        right: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--accent2);
        opacity: 0;
        transition: all 0.2s;
      }

      .post-card-small:hover {
        border-color: var(--border-hover);
        background: var(--bg3);
        padding-right: 2.5rem;
      }
      .post-card-small:hover::after { opacity: 1; }

      .post-card-small .post-title {
        font-size: 0.95rem;
        margin: 0;
      }

      .post-card-small .post-desc {
        font-size: 0.8rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* NEWSLETTER */
      .newsletter {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 3rem;
        margin-bottom: 5rem;
        position: relative;
        overflow: hidden;
      }

      .newsletter::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(124,107,255,0.08) 0%, transparent 70%);
        pointer-events: none;
      }

      .newsletter-inner { position: relative; max-width: 480px; }

      .newsletter h2 {
        font-family: 'Syne', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
      }

      .newsletter p {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 1.5rem;
        font-weight: 300;
      }

      .newsletter-form {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .newsletter-form input {
        flex: 1;
        min-width: 200px;
        background: var(--bg3);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 0.7rem 1rem;
        border-radius: 8px;
        font-size: 0.875rem;
        font-family: 'DM Sans', sans-serif;
        outline: none;
        transition: border-color 0.2s;
      }
      .newsletter-form input:focus { border-color: var(--accent); }
      .newsletter-form input::placeholder { color: var(--text-dim); }

      .newsletter-form button {
        background: var(--accent);
        color: white;
        border: none;
        padding: 0.7rem 1.25rem;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: opacity 0.2s;
      }
      .newsletter-form button:hover { opacity: 0.85; }

      /* FOOTER */
      footer {
        border-top: 1px solid var(--border);
        padding: 2rem 0 3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .footer-logo {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 1rem;
        color: var(--text-muted);
        text-decoration: none;
      }
      .footer-logo span { color: var(--accent2); }

      .footer-text {
        font-size: 0.8rem;
        color: var(--text-dim);
      }

      /* ANIMATIONS */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .hero-label { animation: fadeUp 0.5s ease both; }
      h1 { animation: fadeUp 0.5s ease 0.1s both; }
      .hero-sub { animation: fadeUp 0.5s ease 0.2s both; }
      .hero-actions { animation: fadeUp 0.5s ease 0.3s both; }
      .stats { animation: fadeUp 0.5s ease 0.4s both; }
    </style>
  </head>
  <body>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <!-- NAV -->
    <nav>
      <a href="/" class="nav-logo">flowfy<span>.</span>de</a>
      <div class="nav-links">
        <a href="/blog">Alle Artikel</a>
        <a href="#newsletter">Newsletter</a>
        <a href="https://claude.ai" target="_blank" class="nav-cta">Claude testen →</a>
      </div>
    </nav>

    <div class="wrapper">

      <!-- HERO -->
      <section class="hero">
        <div class="hero-label">KI für Einsteiger</div>
        <h1>KI einfach <span class="gradient">verstehen</span> & nutzen</h1>
        <p class="hero-sub">
          Praktische Guides, ehrliche Tests und konkrete Prompts — damit du Claude, ChatGPT und Co. wirklich nutzen kannst. Kein Fachwissen nötig.
        </p>
        <div class="hero-actions">
          <a href="/blog" class="btn-primary">Alle Artikel lesen →</a>
          <a href="#newsletter" class="btn-secondary">Newsletter abonnieren</a>
        </div>
      </section>

      <!-- STATS -->
      <div class="stats">
        <div class="stat-item">
          <div class="stat-num">{posts.length}<span>+</span></div>
          <div class="stat-label">Artikel</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">100<span>%</span></div>
          <div class="stat-label">Kostenlos</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">0</div>
          <div class="stat-label">Fachwissen nötig</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">5<span>min</span></div>
          <div class="stat-label">Lesezeit pro Artikel</div>
        </div>
      </div>

      <!-- FEATURED POSTS -->
      {posts.length > 0 && (
        <section>
          <div class="section-header">
            <h2 class="section-title">Neueste Artikel</h2>
            <a href="/blog" class="section-link">Alle ansehen →</a>
          </div>

          <div class="featured">
            {posts.slice(0, 1).map(post => (
              <a href={`/blog/${post.slug}/`} class="post-card featured-main">
                {post.data.heroImage && (
					<img src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage.src} alt={post.data.title} class="post-img" />
				)}
                <div class="post-body">
                  <span class="post-tag">Neuester Artikel</span>
                  <div class="post-title">{post.data.title}</div>
                  <p class="post-desc">{post.data.description}</p>
                  <div class="post-meta">
                    <span class="post-date">{post.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                    <span class="post-arrow">→</span>
                  </div>
                </div>
              </a>
            ))}

            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
              {posts.slice(1, 3).map(post => (
                <a href={`/blog/${post.slug}/`} class="post-card">
                  <div class="post-body">
                    <span class="post-tag">Guide</span>
                    <div class="post-title">{post.data.title}</div>
                    <p class="post-desc">{post.data.description}</p>
                    <div class="post-meta">
                      <span class="post-date">{post.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                      <span class="post-arrow">→</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>

          {posts.length > 3 && (
            <div class="posts-grid">
              {posts.slice(3).map(post => (
                <a href={`/blog/${post.slug}/`} class="post-card-small">
                  <span class="post-tag">Artikel</span>
                  <div class="post-title">{post.data.title}</div>
                  <p class="post-desc">{post.data.description}</p>
                  <div class="post-date" style="margin-top: 0.5rem;">{post.data.pubDate.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}</div>
                </a>
              ))}
            </div>
          )}
        </section>
      )}

      <!-- NEWSLETTER -->
      <section class="newsletter" id="newsletter">
        <div class="newsletter-inner">
          <h2>KI-Tipps direkt ins Postfach</h2>
          <p>Jede Woche ein neuer Artikel — praktische Prompts, Tool-Tests und Guides die dir wirklich helfen. Kein Spam, jederzeit abmeldbar.</p>
          <form class="newsletter-form" onsubmit="return false;">
            <input type="email" placeholder="deine@email.de" />
            <button type="submit">Abonnieren</button>
          </form>
        </div>
      </section>

      <!-- FOOTER -->
      <footer>
        <a href="/" class="footer-logo">flowfy<span>.</span>de</a>
        <span class="footer-text">KI einfach erklärt — {new Date().getFullYear()}</span>
      </footer>

    </div>
  </body>
</html>
