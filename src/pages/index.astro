---
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Flowfy — KI einfach verstehen & nutzen</title>
  <meta name="description" content="Praktische Guides, ehrliche Tests und konkrete Prompts für Claude, ChatGPT und Co. Kein Fachwissen nötig." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Sans:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f8f7f4;
      --bg2: #f0ede8;
      --surface: #ffffff;
      --border: #e8e4dd;
      --border2: #d4cfc7;
      --text: #1a1815;
      --text2: #6b6660;
      --text3: #9b9590;
      --accent: #1a6b4a;
      --accent-light: #e8f4ee;
      --accent2: #2d8f65;
      --accent-glow: rgba(26,107,74,0.12);
      --radius: 12px;
      --radius-lg: 20px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
      --shadow: 0 4px 16px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
      --shadow-lg: 0 20px 60px rgba(0,0,0,0.1), 0 4px 16px rgba(0,0,0,0.06);
    }

    html { background: var(--bg); color: var(--text); font-family: 'Instrument Sans', sans-serif; scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
    body { overflow-x: hidden; }

    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: 64px; display: flex; align-items: center; justify-content: space-between;
      padding: 0 max(2rem, calc((100vw - 1200px) / 2));
      background: rgba(248,247,244,0.88); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: 'Cabinet Grotesk', sans-serif; font-weight: 900; font-size: 1.25rem;
      color: var(--text); text-decoration: none; letter-spacing: -0.03em;
    }
    .nav-logo span { color: var(--accent); }

    .nav-links { display: flex; gap: 0.25rem; align-items: center; }
    .nav-links a { font-size: 0.875rem; color: var(--text2); text-decoration: none; padding: 0.4rem 0.75rem; border-radius: 8px; transition: all 0.15s; font-weight: 500; }
    .nav-links a:hover { color: var(--text); background: var(--bg2); }
    .nav-cta { background: var(--accent) !important; color: white !important; }
    .nav-cta:hover { background: var(--accent2) !important; }

    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

    .hero {
      padding: 140px 0 80px;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 4rem; align-items: center;
    }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.75rem; font-weight: 500; color: var(--accent);
      background: var(--accent-light); border: 1px solid rgba(26,107,74,0.2);
      padding: 0.3rem 0.75rem; border-radius: 100px; margin-bottom: 1.25rem;
    }
    .badge-dot { width: 6px; height: 6px; background: var(--accent); border-radius: 50%; animation: pulse 2s ease infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

    h1 {
      font-family: 'Cabinet Grotesk', sans-serif;
      font-size: clamp(2.6rem, 5vw, 4rem); font-weight: 900;
      line-height: 1.06; letter-spacing: -0.04em; color: var(--text); margin-bottom: 1.25rem;
    }
    h1 em {
      font-style: normal;
      background: linear-gradient(135deg, var(--accent) 0%, #2563eb 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }

    .hero-sub { font-size: 1.1rem; color: var(--text2); line-height: 1.7; margin-bottom: 2rem; max-width: 44ch; }
    .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }

    .btn {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.7rem 1.4rem; border-radius: var(--radius);
      font-size: 0.9rem; font-weight: 500; text-decoration: none;
      transition: all 0.2s; font-family: 'Instrument Sans', sans-serif;
    }
    .btn-primary { background: var(--accent); color: white; box-shadow: var(--shadow-sm); }
    .btn-primary:hover { background: var(--accent2); transform: translateY(-1px); box-shadow: var(--shadow); }
    .btn-outline { background: white; color: var(--text); border: 1px solid var(--border2); box-shadow: var(--shadow-sm); }
    .btn-outline:hover { background: var(--bg2); transform: translateY(-1px); }

    .hero-trust { display: flex; align-items: center; gap: 0.75rem; font-size: 0.8rem; color: var(--text3); }
    .trust-avatars { display: flex; }
    .trust-avatars span {
      width: 28px; height: 28px; border-radius: 50%; border: 2px solid white;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.65rem; font-weight: 700; color: white; margin-left: -6px;
    }
    .trust-avatars span:first-child { margin-left: 0; }

    .hero-visual { position: relative; }

    .hero-card {
      background: white; border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg); border: 1px solid var(--border); overflow: hidden;
    }
    .card-header {
      background: var(--bg); padding: 0.85rem 1.25rem; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 0.4rem;
    }
    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot-r { background: #ff5f57; } .dot-y { background: #febc2e; } .dot-g { background: #28c840; }
    .card-label { font-size: 0.72rem; color: var(--text3); margin-left: 0.4rem; }
    .card-body { padding: 1.5rem; }

    .chat { display: flex; gap: 0.75rem; margin-bottom: 1rem; }
    .chat:nth-child(1){animation:fadeUp 0.4s ease 0.2s both}
    .chat:nth-child(2){animation:fadeUp 0.4s ease 0.5s both}
    .chat:nth-child(3){animation:fadeUp 0.4s ease 0.8s both}
    .chat:nth-child(4){animation:fadeUp 0.4s ease 1.1s both}

    .av {
      width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.65rem; font-weight: 700; color: white;
    }
    .av-u { background: linear-gradient(135deg,#667eea,#764ba2); }
    .av-a { background: linear-gradient(135deg,var(--accent),#2563eb); }

    .bubble { background: var(--bg); border-radius: 10px; padding: 0.6rem 0.85rem; font-size: 0.8rem; line-height: 1.5; color: var(--text); max-width: 88%; }
    .bubble.ai { background: var(--accent-light); }
    .typing { display: flex; gap: 4px; align-items: center; }
    .typing span { width: 5px; height: 5px; background: var(--accent); border-radius: 50%; animation: bounce 1.2s ease infinite; }
    .typing span:nth-child(2){animation-delay:0.15s} .typing span:nth-child(3){animation-delay:0.3s}

    @keyframes bounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-5px)} }
    @keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }

    .float-badge {
      position: absolute; background: white; border-radius: var(--radius);
      padding: 0.65rem 1rem; box-shadow: var(--shadow); border: 1px solid var(--border);
      font-size: 0.75rem; display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;
    }
    .float-1 { top: -18px; right: -16px; animation: float 3s ease-in-out infinite; }
    .float-2 { bottom: 16px; left: -16px; animation: float 3s ease-in-out infinite 1.5s; }

    .logos { padding: 3rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); margin-bottom: 6rem; }
    .logos-label { text-align: center; font-size: 0.75rem; color: var(--text3); margin-bottom: 1.5rem; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 500; }
    .logos-row { display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap; }
    .logo-name { font-family: 'Cabinet Grotesk', sans-serif; font-weight: 800; font-size: 1.05rem; color: var(--text3); opacity: 0.45; transition: opacity 0.2s; }
    .logo-name:hover { opacity: 0.75; }

    .section { margin-bottom: 6rem; }
    .sec-tag { font-size: 0.72rem; font-weight: 600; color: var(--accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.6rem; }
    .sec-title { font-family: 'Cabinet Grotesk', sans-serif; font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 900; letter-spacing: -0.03em; color: var(--text); margin-bottom: 0.75rem; }
    .sec-sub { font-size: 0.95rem; color: var(--text2); line-height: 1.7; max-width: 50ch; }
    .sec-row { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1.5rem; }

    .features { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 1.25rem; }
    .feat {
      background: white; border: 1px solid var(--border); border-radius: var(--radius-lg);
      padding: 1.6rem; transition: all 0.2s; position: relative; overflow: hidden;
    }
    .feat::after { content:''; position:absolute; inset:0; background:linear-gradient(135deg,var(--accent-glow) 0%,transparent 55%); opacity:0; transition:opacity 0.2s; border-radius:var(--radius-lg); }
    .feat:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
    .feat:hover::after { opacity: 1; }
    .feat-icon { font-size: 1.5rem; margin-bottom: 0.85rem; }
    .feat-title { font-family: 'Cabinet Grotesk', sans-serif; font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 0.4rem; }
    .feat-desc { font-size: 0.855rem; color: var(--text2); line-height: 1.6; }

    .articles { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }
    .art {
      background: white; border: 1px solid var(--border); border-radius: var(--radius-lg);
      overflow: hidden; text-decoration: none; display: flex; flex-direction: column; transition: all 0.2s;
    }
    .art:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
    .art img { width: 100%; aspect-ratio: 16/9; object-fit: cover; filter: saturate(0.85); }
    .art-body { padding: 1.25rem 1.5rem 1.5rem; flex: 1; display: flex; flex-direction: column; }
    .art-tag { font-size: 0.68rem; font-weight: 600; color: var(--accent); background: var(--accent-light); padding: 0.18rem 0.55rem; border-radius: 4px; margin-bottom: 0.65rem; display: inline-block; text-transform: uppercase; letter-spacing: 0.04em; }
    .art-title { font-family: 'Cabinet Grotesk', sans-serif; font-size: 0.95rem; font-weight: 700; color: var(--text); line-height: 1.3; margin-bottom: 0.45rem; }
    .art-desc { font-size: 0.825rem; color: var(--text2); line-height: 1.6; flex: 1; }
    .art-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; padding-top: 0.85rem; border-top: 1px solid var(--border); }
    .art-date { font-size: 0.72rem; color: var(--text3); }
    .art-arr { font-size: 0.85rem; color: var(--accent); transition: transform 0.15s; }
    .art:hover .art-arr { transform: translateX(3px); }

    .newsletter {
      background: var(--text); border-radius: var(--radius-lg); padding: 4rem;
      margin-bottom: 6rem; display: grid; grid-template-columns: 1fr 1fr;
      gap: 3rem; align-items: center; position: relative; overflow: hidden;
    }
    .newsletter::before {
      content:''; position:absolute; width:400px; height:400px; border-radius:50%;
      background: radial-gradient(circle,rgba(26,107,74,0.15) 0%,transparent 70%);
      top:-100px; right:-100px; pointer-events:none;
    }
    .newsletter h2 { font-family: 'Cabinet Grotesk', sans-serif; font-size: 1.9rem; font-weight: 900; color: white; letter-spacing: -0.03em; margin-bottom: 0.75rem; }
    .newsletter p { font-size: 0.875rem; color: rgba(255,255,255,0.55); line-height: 1.7; }
    .nl-form { display: flex; flex-direction: column; gap: 0.65rem; }
    .nl-form input {
      background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);
      color: white; padding: 0.8rem 1rem; border-radius: var(--radius);
      font-size: 0.875rem; font-family: 'Instrument Sans', sans-serif;
      outline: none; transition: border-color 0.2s;
    }
    .nl-form input::placeholder { color: rgba(255,255,255,0.3); }
    .nl-form input:focus { border-color: var(--accent2); }
    .nl-form button {
      background: var(--accent); color: white; border: none;
      padding: 0.8rem; border-radius: var(--radius); font-size: 0.875rem;
      font-weight: 600; cursor: pointer; font-family: 'Instrument Sans', sans-serif; transition: background 0.2s;
    }
    .nl-form button:hover { background: var(--accent2); }
    .nl-note { font-size: 0.72rem; color: rgba(255,255,255,0.28); margin-top: 0.5rem; }

    .bottom-cta {
      text-align: center; padding: 5rem 2rem; margin-bottom: 5rem;
      background: white; border-radius: var(--radius-lg); border: 1px solid var(--border);
      position: relative; overflow: hidden;
    }
    .bottom-cta::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 50% 0%,var(--accent-glow) 0%,transparent 55%); }
    .bottom-cta-inner { position: relative; }
    .bottom-cta h2 { font-family: 'Cabinet Grotesk', sans-serif; font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 900; letter-spacing: -0.03em; margin-bottom: 0.85rem; }
    .bottom-cta p { font-size: 0.95rem; color: var(--text2); margin-bottom: 2rem; }
    .cta-btns { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

    footer { border-top: 1px solid var(--border); padding: 3rem 0 1.5rem; display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2rem; }
    .footer-brand p { font-size: 0.8rem; color: var(--text3); line-height: 1.6; max-width: 22ch; margin-top: 0.6rem; }
    .footer-col h4 { font-size: 0.78rem; font-weight: 600; color: var(--text); margin-bottom: 0.75rem; }
    .footer-col a { display: block; font-size: 0.8rem; color: var(--text3); text-decoration: none; margin-bottom: 0.45rem; transition: color 0.15s; }
    .footer-col a:hover { color: var(--text); }
    .footer-bottom { border-top: 1px solid var(--border); padding: 1.25rem 0; margin-top: 1.5rem; font-size: 0.75rem; color: var(--text3); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }

    .reveal { opacity: 0; transform: translateY(20px); transition: all 0.55s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .d1 { transition-delay: 0.1s; } .d2 { transition-delay: 0.2s; } .d3 { transition-delay: 0.3s; }

    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; padding: 110px 0 60px; gap: 2.5rem; }
      .hero-visual { order: -1; }
      .nav-links { display: none; }
      .newsletter { grid-template-columns: 1fr; padding: 2.5rem; }
      footer { grid-template-columns: 1fr 1fr; }
      .float-1, .float-2 { display: none; }
    }
  </style>
</head>
<body>

<nav>
  <a href="/" class="nav-logo">Flowfy<span>.</span></a>
  <div class="nav-links">
    <a href="/ratgeber">KI-Ratgeber</a>
    <a href="/blog">Blog</a>
    <a href="/ueber-mich">Über mich</a>
    <a href="/kontakt">Kontakt</a>
    <a href="https://claude.ai" target="_blank" class="nav-cta">Claude testen →</a>
  </div>
</nav>

<div class="wrap">
  <section class="hero">
    <div>
      <div class="hero-badge"><span class="badge-dot"></span> KI-Guides auf Deutsch</div>
      <h1>KI <em>verstehen</em> — ohne Studium</h1>
      <p class="hero-sub">Praktische Guides, ehrliche Tests und konkrete Prompts für Claude, ChatGPT und Co. Kein Fachwissen nötig — nur Neugier.</p>
      <div class="hero-actions">
        <a href="/ratgeber" class="btn btn-primary">Jetzt loslegen →</a>
        <a href="/blog" class="btn btn-outline">Neueste Artikel</a>
      </div>
      <div class="hero-trust">
        <div class="trust-avatars">
          <span style="background:linear-gradient(135deg,#667eea,#764ba2)">M</span>
          <span style="background:linear-gradient(135deg,#f093fb,#f5576c)">S</span>
          <span style="background:linear-gradient(135deg,#4facfe,#00f2fe)">T</span>
          <span style="background:linear-gradient(135deg,#43e97b,#38f9d7)">L</span>
        </div>
        Bereits hunderte Leser dabei
      </div>
    </div>

    <div class="hero-visual">
      <div class="float-badge float-1">
        <span style="font-size:1rem">⚡</span>
        <span style="color:var(--text2)">Antwort in <strong style="color:var(--accent)">2 Sek.</strong></span>
      </div>
      <div class="hero-card">
        <div class="card-header">
          <span class="dot dot-r"></span><span class="dot dot-y"></span><span class="dot dot-g"></span>
          <span class="card-label">Claude AI — Gespräch</span>
        </div>
        <div class="card-body">
          <div class="chat">
            <div class="av av-u">Du</div>
            <div class="bubble">Was ist ein Prompt und wie schreibe ich einen guten?</div>
          </div>
          <div class="chat">
            <div class="av av-a">AI</div>
            <div class="bubble ai">Ein Prompt ist einfach das, was du einer KI schreibst — wie eine Nachricht an einen sehr klugen Assistenten. Je genauer du schreibst, desto besser die Antwort. 💡</div>
          </div>
          <div class="chat">
            <div class="av av-u">Du</div>
            <div class="bubble">Gib mir ein konkretes Beispiel.</div>
          </div>
          <div class="chat">
            <div class="av av-a">AI</div>
            <div class="bubble ai"><div class="typing"><span></span><span></span><span></span></div></div>
          </div>
        </div>
      </div>
      <div class="float-badge float-2">
        <span style="font-size:1rem">✅</span>
        <span style="color:var(--text2)"><strong style="color:var(--text)">100%</strong> kostenlos starten</span>
      </div>
    </div>
  </section>
</div>

<div class="wrap">
  <div class="logos reveal">
    <p class="logos-label">Über diese KI-Tools schreiben wir</p>
    <div class="logos-row">
      <span class="logo-name">Claude</span>
      <span class="logo-name">ChatGPT</span>
      <span class="logo-name">Gemini</span>
      <span class="logo-name">Perplexity</span>
      <span class="logo-name">Midjourney</span>
      <span class="logo-name">Copilot</span>
    </div>
  </div>
</div>

<div class="wrap">
  <section class="section">
    <div class="sec-row">
      <div>
        <div class="sec-tag reveal">Was dich erwartet</div>
        <h2 class="sec-title reveal d1">Alles was du brauchst,<br>um KI wirklich zu nutzen</h2>
        <p class="sec-sub reveal d2">Keine Theorie, keine Buzzwords — nur praktisches Wissen das du sofort anwenden kannst.</p>
      </div>
    </div>
    <div class="features">
      <div class="feat reveal"><div class="feat-icon">📖</div><div class="feat-title">Ehrliche Guides</div><div class="feat-desc">Kein Werbesprech — wir testen Tools selbst und erklären dir was wirklich funktioniert und was nicht.</div></div>
      <div class="feat reveal d1"><div class="feat-icon">⚡</div><div class="feat-title">Prompts zum Kopieren</div><div class="feat-desc">Fertige Prompts die du 1:1 verwenden kannst — für E-Mails, Zusammenfassungen, Ideen und mehr.</div></div>
      <div class="feat reveal d2"><div class="feat-icon">🆚</div><div class="feat-title">Tool-Vergleiche</div><div class="feat-desc">Claude vs. ChatGPT, Gratis vs. Pro — wir vergleichen ehrlich damit du das richtige Tool wählst.</div></div>
      <div class="feat reveal"><div class="feat-icon">🎯</div><div class="feat-title">Für Anfänger gemacht</div><div class="feat-desc">Null Vorkenntnisse nötig. Jeder Artikel erklärt Begriffe wenn sie auftauchen — kein Googeln nötig.</div></div>
      <div class="feat reveal d1"><div class="feat-icon">💰</div><div class="feat-title">Kostenlos nutzbar</div><div class="feat-desc">Alle empfohlenen Tools haben kostenlose Versionen. Wir zeigen dir wie du ohne Kreditkarte startest.</div></div>
      <div class="feat reveal d2"><div class="feat-icon">🔄</div><div class="feat-title">Immer aktuell</div><div class="feat-desc">KI entwickelt sich schnell. Unsere Artikel werden regelmäßig aktualisiert wenn sich etwas ändert.</div></div>
    </div>
  </section>
</div>

{posts.length > 0 && (
  <div class="wrap">
    <section class="section">
      <div class="sec-row">
        <div>
          <div class="sec-tag reveal">Neueste Artikel</div>
          <h2 class="sec-title reveal d1">Direkt loslegen</h2>
        </div>
        <a href="/blog" class="btn btn-outline reveal">Alle Artikel →</a>
      </div>
      <div class="articles">
        {posts.map((post, i) => (
          <a href={`/blog/${post.slug}/`} class={`art reveal d${i}`}>
            {post.data.heroImage && (
              <img
                src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage.src}
                alt={post.data.title}
              />
            )}
            <div class="art-body">
              <span class="art-tag">Guide</span>
              <div class="art-title">{post.data.title}</div>
              <p class="art-desc">{post.data.description}</p>
              <div class="art-meta">
                <span class="art-date">{post.data.pubDate.toLocaleDateString('de-DE', { day:'numeric', month:'long', year:'numeric' })}</span>
                <span class="art-arr">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
