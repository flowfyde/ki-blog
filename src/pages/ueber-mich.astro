<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Über mich — Flowfy</title>
  <meta name="description" content="Wer steckt hinter Flowfy? Ein Mensch der KI früh entdeckt hat, ausprobiert und jetzt teilt was wirklich funktioniert." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Sans:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f8f7f4; --bg2: #f0ede8; --surface: #ffffff;
      --border: #e8e4dd; --border2: #d4cfc7;
      --text: #1a1815; --text2: #6b6660; --text3: #9b9590;
      --accent: #1a6b4a; --accent-light: #e8f4ee; --accent2: #2d8f65;
      --radius: 12px; --radius-lg: 20px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
      --shadow: 0 4px 16px rgba(0,0,0,0.08);
    }
    html { background: var(--bg); color: var(--text); font-family: 'Instrument Sans', sans-serif; -webkit-font-smoothing: antialiased; }
    body { overflow-x: hidden; }

    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 max(2rem, calc((100vw - 1200px) / 2));
      background: rgba(248,247,244,0.88); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-family: 'Cabinet Grotesk', sans-serif; font-weight: 900; font-size: 1.25rem; color: var(--text); text-decoration: none; letter-spacing: -0.03em; }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 0.25rem; align-items: center; }
    .nav-links a { font-size: 0.875rem; color: var(--text2); text-decoration: none; padding: 0.4rem 0.75rem; border-radius: 8px; transition: all 0.15s; font-weight: 500; }
    .nav-links a:hover, .nav-links a.active { color: var(--text); background: var(--bg2); }
    .nav-cta { background: var(--accent) !important; color: white !important; }
    .nav-cta:hover { background: var(--accent2) !important; }

    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
    .wrap-narrow { max-width: 760px; margin: 0 auto; padding: 0 2rem; }

    /* HERO */
    .hero {
      padding: 140px 0 5rem;
      display: grid; grid-template-columns: 1fr 340px;
      gap: 5rem; align-items: start;
    }

    .hero-tag { font-size: 0.72rem; font-weight: 600; color: var(--accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.6rem; }
    h1 { font-family: 'Cabinet Grotesk', sans-serif; font-size: clamp(2.2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -0.04em; color: var(--text); margin-bottom: 1.25rem; line-height: 1.08; }
    h1 span { color: var(--accent); }

    .lead { font-size: 1.05rem; color: var(--text2); line-height: 1.75; margin-bottom: 2rem; }

    .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
    .tag {
      font-size: 0.78rem; font-weight: 500; padding: 0.3rem 0.8rem;
      border-radius: 100px; border: 1px solid var(--border2);
      background: white; color: var(--text2);
    }

    .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.65rem 1.3rem; border-radius: var(--radius); font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: all 0.2s; font-family: 'Instrument Sans', sans-serif; }
    .btn-primary { background: var(--accent); color: white; box-shadow: var(--shadow-sm); }
    .btn-primary:hover { background: var(--accent2); transform: translateY(-1px); }
    .btn-outline { background: white; color: var(--text); border: 1px solid var(--border2); box-shadow: var(--shadow-sm); }
    .btn-outline:hover { background: var(--bg2); transform: translateY(-1px); }

    /* PROFILE CARD */
    .profile-card {
      background: white; border: 1px solid var(--border);
      border-radius: var(--radius-lg); overflow: hidden;
      box-shadow: var(--shadow); position: sticky; top: 88px;
    }
    .profile-img-wrap {
      background: linear-gradient(135deg, var(--accent-light) 0%, #dbeafe 100%);
      padding: 2.5rem 2rem 1.5rem; text-align: center;
    }
    .profile-avatar {
      width: 90px; height: 90px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), #2563eb);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cabinet Grotesk', sans-serif; font-size: 2rem; font-weight: 900;
      color: white; margin: 0 auto 1rem; border: 4px solid white;
      box-shadow: var(--shadow);
    }
    .profile-name { font-family: 'Cabinet Grotesk', sans-serif; font-size: 1.1rem; font-weight: 800; color: var(--text); letter-spacing: -0.02em; }
    .profile-role { font-size: 0.8rem; color: var(--text2); margin-top: 0.25rem; }

    .profile-body { padding: 1.5rem; }
    .profile-stat { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 0; border-bottom: 1px solid var(--border); font-size: 0.82rem; }
    .profile-stat:last-of-type { border-bottom: none; }
    .profile-stat-label { color: var(--text3); }
    .profile-stat-value { font-weight: 500; color: var(--text); }
    .profile-stat-value.green { color: var(--accent); }

    .profile-divider { height: 1px; background: var(--border); margin: 0.5rem 0; }

    /* CONTENT */
    .content { padding: 0 0 5rem; }

    .section { margin-bottom: 4rem; }
    .section-title { font-family: 'Cabinet Grotesk', sans-serif; font-size: 1.4rem; font-weight: 800; color: var(--text); letter-spacing: -0.02em; margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 2px solid var(--accent-light); }

    .prose p { font-size: 0.95rem; color: var(--text2); line-height: 1.8; margin-bottom: 1.1rem; }
    .prose p:last-child { margin-bottom: 0; }
    .prose strong { color: var(--text); font-weight: 600; }

    /* TIMELINE */
    .timeline { display: flex; flex-direction: column; gap: 0; }
    .tl-item { display: flex; gap: 1.25rem; padding-bottom: 2rem; position: relative; }
    .tl-item:last-child { padding-bottom: 0; }
    .tl-left { display: flex; flex-direction: column; align-items: center; width: 36px; flex-shrink: 0; }
    .tl-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--accent); border: 3px solid white; box-shadow: 0 0 0 2px var(--accent); flex-shrink: 0; margin-top: 4px; }
    .tl-line { width: 2px; flex: 1; background: var(--border); margin-top: 6px; }
    .tl-item:last-child .tl-line { display: none; }
    .tl-year { font-size: 0.72rem; font-weight: 600; color: var(--accent); margin-bottom: 0.3rem; }
    .tl-title { font-family: 'Cabinet Grotesk', sans-serif; font-size: 0.95rem; font-weight: 700; color: var(--text); margin-bottom: 0.3rem; }
    .tl-desc { font-size: 0.83rem; color: var(--text2); line-height: 1.6; }

    /* VALUES */
    .values { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .value-card { background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; }
    .value-icon { font-size: 1.3rem; margin-bottom: 0.6rem; }
    .value-title { font-family: 'Cabinet Grotesk', sans-serif; font-size: 0.9rem; font-weight: 700; color: var(--text); margin-bottom: 0.35rem; }
    .value-desc { font-size: 0.8rem; color: var(--text2); line-height: 1.55; }

    /* TOOLS */
    .tools { display: flex; flex-wrap: wrap; gap: 0.6rem; }
    .tool-badge { display: flex; align-items: center; gap: 0.4rem; background: white; border: 1px solid var(--border); border-radius: 8px; padding: 0.45rem 0.85rem; font-size: 0.82rem; font-weight: 500; color: var(--text); }

    /* CTA BLOCK */
    .cta-block {
      background: var(--text); border-radius: var(--radius-lg);
      padding: 3rem; text-align: center; margin-bottom: 5rem;
      position: relative; overflow: hidden;
    }
    .cta-block::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 50% 0%,rgba(26,107,74,0.2) 0%,transparent 60%); }
    .cta-inner { position: relative; }
    .cta-block h2 { font-family: 'Cabinet Grotesk', sans-serif; font-size: 1.6rem; font-weight: 900; color: white; letter-spacing: -0.03em; margin-bottom: 0.6rem; }
    .cta-block p { font-size: 0.875rem; color: rgba(255,255,255,0.55); margin-bottom: 1.5rem; }
    .cta-btns { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .btn-white { background: white; color: var(--text); }
    .btn-white:hover { background: var(--bg2); }
    .btn-ghost { background: transparent; color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.2); }
    .btn-ghost:hover { background: rgba(255,255,255,0.08); color: white; }

    footer { border-top: 1px solid var(--border); padding: 2rem 0; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .footer-logo { font-family: 'Cabinet Grotesk', sans-serif; font-weight: 900; font-size: 1rem; color: var(--text2); text-decoration: none; }
    .footer-logo span { color: var(--accent); }
    .footer-links { display: flex; gap: 1.5rem; }
    .footer-links a { font-size: 0.78rem; color: var(--text3); text-decoration: none; transition: color 0.15s; }
    .footer-links a:hover { color: var(--text); }

    .reveal { opacity: 0; transform: translateY(16px); transition: all 0.5s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .d1 { transition-delay: 0.1s; } .d2 { transition-delay: 0.2s; }

    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; gap: 2.5rem; }
      .profile-card { position: static; }
      .values { grid-template-columns: 1fr; }
      .nav-links { display: none; }
    }
  </style>
</head>
<body>

<nav>
  <a href="/" class="nav-logo">Flowfy<span>.</span></a>
  <div class="nav-links">
    <a href="/ratgeber">KI-Ratgeber</a>
    <a href="/blog">Blog</a>
    <a href="/ueber-mich" class="active">Über mich</a>
    <a href="/kontakt">Kontakt</a>
    <a href="https://claude.ai" target="_blank" class="nav-cta">Claude testen →</a>
  </div>
</nav>

<div class="wrap">
  <section class="hero">
    <div>
      <div class="hero-tag reveal">Über mich</div>
      <h1 class="reveal d1">Hallo, ich bin der <span>Kopf</span> hinter Flowfy.</h1>
      <p class="lead reveal d2">Ich bin Mitte 30, arbeite tagsüber in einem normalen Job — und beschäftige mich nebenbei intensiv mit KI-Tools. Nicht weil es Trend ist, sondern weil es mich wirklich fasziniert wie diese Technologie den Alltag verändert.</p>

      <div class="tags reveal">
        <span class="tag">🏙 Bensheim</span>
        <span class="tag">💼 Angestellt & Blogger</span>
        <span class="tag">🤖 KI-Enthusiast</span>
        <span class="tag">✍️ Autor</span>
      </div>

      <div class="hero-actions reveal">
        <a href="/blog" class="btn btn-primary">Meine Artikel lesen</a>
        <a href="/kontakt" class="btn btn-outline">Kontakt aufnehmen</a>
      </div>
    </div>

    <div class="reveal d1">
      <div class="profile-card">
        <div class="profile-img-wrap">
          <div class="profile-avatar">F</div>
          <div class="profile-name">Flowfy-Autor</div>
          <div class="profile-role">KI-Blogger & Enthusiast</div>
        </div>
        <div class="profile-body">
          <div class="profile-stat">
            <span class="profile-stat-label">Standort</span>
            <span class="profile-stat-value">Bensheim, DE</span>
          </div>
          <div class="profile-stat">
            <span class="profile-stat-label">Artikel veröffentlicht</span>
            <span class="profile-stat-value green">wächst wöchentlich</span>
          </div>
          <div class="profile-stat">
            <span class="profile-stat-label">KI-Tools getestet</span>
            <span class="profile-stat-value">10+</span>
          </div>
          <div class="profile-stat">
            <span class="profile-stat-label">Lieblings-Tool</span>
            <span class="profile-stat-value green">Claude AI</span>
          </div>
          <div class="profile-stat">
            <span class="profile-stat-label">Erreichbar via</span>
            <span class="profile-stat-value"><a href="/kontakt" style="color:var(--accent);text-decoration:none">Kontaktformular</a></span>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<div class="wrap" style="display:grid;grid-template-columns:1fr 340px;gap:5rem;align-items:start;padding-bottom:0">

  <div class="content">

    <section class="section reveal">
      <div class="section-title">Meine Geschichte</div>
      <div class="prose">
        <p>Als ChatGPT Ende 2022 erschien, war ich neugierig — aber skeptisch. Noch ein Hype-Thema, dachte ich. Dann habe ich es ausprobiert. Und nochmal. Und nochmal.</p>
        <p>Was mich wirklich gepackt hat, war nicht die Technologie selbst — sondern der Moment wo ich gemerkt habe: <strong>Das verändert echte Alltagsaufgaben.</strong> E-Mails in Minuten statt Stunden. Komplizierte Verträge endlich verstehen. Ideen strukturieren ohne stundenlang vor dem leeren Blatt zu sitzen.</p>
        <p>Ich bin kein Informatiker. Ich habe kein KI-Studium. Ich bin jemand der im echten Leben getestet hat was funktioniert — und was nicht. Und genau das teile ich hier.</p>
        <p>Flowfy ist mein Nebenprojekt. Aufgebaut nebenbei, Artikel für Artikel. Das Ziel: KI-Tools so erklären wie ich mir das selbst gewünscht hätte — ohne Buzzwords, ohne Hype, mit echten Beispielen.</p>
      </div>
    </section>

    <section class="section reveal">
      <div class="section-title">Mein Weg mit KI</div>
      <div class="timeline">
        <div class="tl-item">
          <div class="tl-left"><div class="tl-dot"></div><div class="tl-line"></div></div>
          <div>
            <div class="tl-year">Ende 2022</div>
            <div class="tl-title">Erster Kontakt mit ChatGPT</div>
            <div class="tl-desc">Skeptisch angefangen, schnell begeistert. Die ersten Experimente mit Prompts — und das Staunen über die Ergebnisse.</div>
          </div>
        </div>
        <div class="tl-item">
          <div class="tl-left"><div class="tl-dot"></div><div class="tl-line"></div></div>
          <div>
            <div class="tl-year">2023</div>
            <div class="tl-title">Deep Dive in Claude & andere Tools</div>
            <div class="tl-desc">Systematisches Testen von Claude, Gemini, Perplexity und mehr. Erste eigene Prompt-Vorlagen entwickelt.</div>
          </div>
        </div>
        <div class="tl-item">
          <div class="tl-left"><div class="tl-dot"></div><div class="tl-line"></div></div>
          <div>
            <div class="tl-year">2024</div>
            <div class="tl-title">KI im Berufsalltag etabliert</div>
            <div class="tl-desc">KI-Tools fest in den Arbeitsalltag integriert. Merklicher Zeitgewinn, klarer Mehrwert — der Entschluss zu bloggen wächst.</div>
          </div>
        </div>
        <div class="tl-item">
          <div class="tl-left"><div class="tl-dot"></div></div>
          <div>
            <div class="tl-year">2025</div>
            <div class="tl-title">Flowfy gestartet</div>
            <div class="tl-desc">Erster Artikel veröffentlicht. Die Mission: KI einfach erklären — für alle die neugierig sind aber keinen Tech-Hintergrund haben.</div>
          </div>
        </div>
      </div>
    </section>

    <section class="section reveal">
      <div class="section-title">Wofür Flowfy steht</div>
      <div class="values">
        <div class="value-card">
          <div class="value-icon">🎯</div>
          <div class="value-title">Ehrlichkeit vor Hype</div>
          <div class="value-desc">Ich schreibe was ich wirklich denke — auch wenn ein Tool enttäuscht. Kein Affiliate-Optimismus.</div>
        </div>
        <div class="value-card">
          <div class="value-icon">🔬</div>
          <div class="value-title">Selbst getestet</div>
          <div class="value-desc">Jedes Tool das ich empfehle habe ich selbst ausgiebig genutzt. Keine Copy-Paste-Artikel.</div>
        </div>
        <div class="value-card">
          <div class="value-icon">📖</div>
          <div class="value-title">Verständlich erklärt</div>
          <div class="value-desc">Kein Fachwissen nötig. Ich erkläre so wie ich mir das selbst gewünscht hätte.</div>
        </div>
        <div class="value-card">
          <div class="value-icon">⚡</div>
          <div class="value-title">Praktisch & umsetzbar</div>
          <div class="value-desc">Jeder Artikel enthält konkrete Tipps die du sofort anwenden kannst — nicht nur Theorie.</div>
        </div>
      </div>
    </section>

    <section class="section reveal">
      <div class="section-title">Tools die ich täglich nutze</div>
      <div class="tools">
        <span class="tool-badge">🤖 Claude AI</span>
        <span class="tool-badge">💬 ChatGPT</span>
        <span class="tool-badge">🔍 Perplexity</span>
        <span class="tool-badge">🎨 Midjourney</span>
        <span class="tool-badge">📝 Notion AI</span>
        <span class="tool-badge">⚡ Claude Code</span>
        <span class="tool-badge">🌐 Gemini</span>
        <span class="tool-badge">🤝 Copilot</span>
      </div>
    </section>

  </div>

  <div style="position:sticky;top:88px" class="reveal d1">
    <div style="background:white;border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.5rem;margin-bottom:1rem;">
      <div style="font-family:'Cabinet Grotesk',sans-serif;font-size:0.9rem;font-weight:700;color:var(--text);margin-bottom:1rem">Neueste Artikel</div>
      <div style="display:flex;flex-direction:column;gap:0.75rem">
        <a href="/blog/was-ist-claude-ai" style="text-decoration:none;font-size:0.82rem;color:var(--text2);line-height:1.4;transition:color 0.15s;display:flex;gap:0.5rem;align-items:flex-start">
          <span style="color:var(--accent);flex-shrink:0">→</span>Was ist Claude AI? Der ehrliche Einsteiger-Guide
        </a>
        <a href="/blog/claude-vs-chatgpt" style="text-decoration:none;font-size:0.82rem;color:var(--text2);line-height:1.4;transition:color 0.15s;display:flex;gap:0.5rem;align-items:flex-start">
          <span style="color:var(--accent);flex-shrink:0">→</span>Claude vs. ChatGPT — welches Tool ist besser?
        </a>
        <a href="/blog/5-claude-prompts-die-du-sofort-nutzen-kannst" style="text-decoration:none;font-size:0.82rem;color:var(--text2);line-height:1.4;transition:color 0.15s;display:flex;gap:0.5rem;align-items:flex-start">
          <span style="color:var(--accent);flex-shrink:0">→</span>5 Claude Prompts die du sofort nutzen kannst
        </a>
      </div>
    </div>

    <div style="background:var(--accent-light);border:1px solid rgba(26,107,74,0.15);border-radius:var(--radius-lg);padding:1.5rem">
      <div style="font-size:1.1rem;margin-bottom:0.5rem">✉️</div>
      <div style="font-family:'Cabinet Grotesk',sans-serif;font-size:0.95rem;font-weight:700;color:var(--text);margin-bottom:0.4rem">Newsletter</div>
      <p style="font-size:0.8rem;color:var(--text2);line-height:1.6;margin-bottom:1rem">Jeden Dienstag: ein neuer Artikel direkt ins Postfach.</p>
      <a href="#newsletter" class="btn btn-primary" style="width:100%;justify-content:center;font-size:0.82rem">Jetzt abonnieren →</a>
    </div>
  </div>

</div>

<div class="wrap">
  <div class="cta-block reveal">
    <div class="cta-inner">
      <h2>Fragen oder Feedback?</h2>
      <p>Ich freue mich über Nachrichten — Themenvorschläge, Kooperationsanfragen oder einfach Hallo.</p>
      <div class="cta-btns">
        <a href="/kontakt" class="btn btn-white">Nachricht schreiben →</a>
        <a href="/blog" class="btn btn-ghost">Artikel lesen</a>
      </div>
    </div>
  </div>
</div>

<div class="wrap">
  <footer>
    <a href="/" class="footer-logo">Flowfy<span>.</span></a>
    <div class="footer-links">
      <a href="/ratgeber">Ratgeber</a>
      <a href="/blog">Blog</a>
      <a href="/kontakt">Kontakt</a>
    </div>
    <span style="font-size:0.75rem;color:var(--text3)">© {new Date().getFullYear()} Flowfy</span>
  </footer>
</div>

<script>
  const obs = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.05 }
  );
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>

</body>
</html>
